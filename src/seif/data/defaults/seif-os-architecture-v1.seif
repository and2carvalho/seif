  "architecture": {
    "principle": "Context daemon on existing OS — don't reinvent syscalls",
    "layers": [
      {
        "name": "Host OS",
        "targets": [
          "macOS",
          "Android",
          "Linux",
          "iOS"
        ],
        "seif_role": "Provides processes, memory, networking"
      },
      {
        "name": "seif-daemon",
