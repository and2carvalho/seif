        "why": "Google dependency trap. Violates sovereignty. Use Android Key Attestation instead."
      },
      {
        "what": "Custom kernel module",
        "why": "Unnecessary complexity, reduces portability."
      }
    ]
  },
  "trust_model": {
    "base": "Ed25519 + owner_challenge_hash (self-sovereign, no third party)",
    "mobile_hardening": "Android Key Attestation (TEE hardware, no Google Play Services required)",
    "classification_tiers": {
      "PUBLIC_INTERNAL": "Ed25519 signature sufficient",
      "CONFIDENTIAL": "Ed25519 + hardware attestation on mobile"
