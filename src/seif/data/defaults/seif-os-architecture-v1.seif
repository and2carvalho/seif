  "threat_model": {
    "target_user": "Solo developer (André) with personal context system",
    "real_threats": [
      "Accidental data loss (deleted files during sync)",
      "Sync corruption (network glitches, partial writes)",
      "AI hallucination / context drift",
      "Human error (misconfigured heartbeats, wrong classification)",
      "Device loss/theft (mobile)"
    ],
    "excluded": [
      "APT/nation-state attacks",
      "Zero-day exploits",
      "Enterprise compliance"
    ],
    "rationale": "If attacker has root, broader system is compromised anyway. SEIF protects context integrity, not OS security."
  },
